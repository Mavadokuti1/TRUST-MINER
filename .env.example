# ── Required ───────────────────────────────────────────────────────────────
# Telegram Bot Token from @BotFather
BOT_TOKEN=your_token_here

# Public base URL of your Render service (no trailing slash), e.g.
# https://trust-miner-bot.onrender.com  — used to register the Telegram webhook.
WEBHOOK_URL=https://your-service.onrender.com

# ── Optional ─────────────────────────────────────────────────────────────────
# Your TrustMRR referral tag, appended (disclosed) to listing links.
AFFILIATE_TAG=your_affiliate_id

# Telegram channel to broadcast the daily digest to (e.g. -100xxxxxxxxxx).
# Leave unset to disable channel broadcasting.
TELEGRAM_CHANNEL_ID=

# Official Twitter/X API v2 credentials (developer account with Read+Write).
# Leave unset to disable tweeting.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Shared secret to protect the /trigger-ingest endpoint. If set, cron-job.org
# must call /trigger-ingest?key=<this value>.
INGEST_SECRET=

# SQLite path (defaults to ./trustmrr_deals.db). On Render's free tier the
# filesystem is ephemeral; the DB is rebuilt by the daily /trigger-ingest run.
DB_PATH=
